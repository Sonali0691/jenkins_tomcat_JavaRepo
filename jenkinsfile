pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    stages {

        stage('Checkout Code') {
    steps {
        git branch: 'main',
            url: https://github.com/Sonali0691/jenkins_tomcat_JavaRepo.git''
    }
}

        stage('Build WAR') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Deploy to Tomcat') {
            steps {
                deploy adapters: [
                    tomcat9(
                        credentialsId: 'tomcat-cred',
                        path: '',
                        url: 'http://15.206.194.246:8080'
                    )
                ],
                contextPath: '',
                war: 'ROOT.war'
            }
        }
    }
}
